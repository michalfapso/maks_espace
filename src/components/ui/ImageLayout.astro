---
export interface Props {
  align: 'left' | 'right' | 'fullwidth';
  maxWidth: string; // Should be a valid CSS value, e.g., "50%", "33%", "25%"
  caption?: string;
}

const { align, maxWidth, caption } = Astro.props;

const getContainerClasses = () => {
  if (align === 'fullwidth') {
    return 'flex flex-col items-center';
  }
  return '';
};

const getImageContainerClasses = () => {
  if (align === 'left') {
    // Mobile-first: no float, full width, no margin
    // Desktop (md+): float left, responsive margin, auto width
    return 'float-none w-full md:float-left md:mr-6 md:w-auto';
  } else if (align === 'right') {
    // Mobile-first: no float, full width, no margin
    // Desktop (md+): float right, responsive margin, auto width
    return 'float-none w-full md:float-right md:ml-6 md:w-auto';
  }
  // fullwidth: no float classes, just w-full (handled by container parent)
  return 'w-full';
};
---

<div class={getContainerClasses()}>
  {/* maxWidth uses inline style because Tailwind lacks arbitrary percentage classes.
      maxWidth should be a valid CSS value like "50%", "33%", "25%" */}
  <div style={`max-width: ${maxWidth}`} class={getImageContainerClasses()}>
    <slot />
  </div>
  {caption && <p class="image-caption">{caption}</p>}
</div>

<style>
  /* Mobile: Disable floats and stack */
  @media (max-width: 767px) {
    :global(.image-container) {
      float: none !important;
      width: 100%;
      margin-left: 0 !important;
      margin-right: 0 !important;
    }
  }

  .image-caption {
    clear: both;
    /* Will be defined in Task 4 */
  }
</style>
