---
// src/components/ui/Gallery.astro
import { Image, getImage } from 'astro:assets';
import HotspotImage from './HotspotImage.astro';
import { parse as parseYaml } from 'yaml';
import type { Hotspot } from './HotspotImage.astro';

interface Props {
  folder: string; // e.g., 'src/assets/galleries/1'
}

interface ImageItem {
  src: any;  // ImageMetadata, but avoid strict mode issue with component-wide any for now
  alt: string;
  hotspots?: Hotspot[];  // Array of Hotspot if available
  lightboxSrc?: string;  // Optimized image URL for lightbox
}

/**
 * Generate alt text from filename by stripping numeric prefix and separators
 * Examples:
 *   "1_podorys.jpg" → "podorys"
 *   "3-bedroom-view.jpg" → "bedroom view"
 *   "image.jpg" → "image"
 */
function generateAltText(filename: string): string {
  // Remove file extension
  const nameWithoutExt = filename.replace(/\.[^/.]+$/, '');

  // Strip leading digits and separators (_, -, space)
  const withoutPrefix = nameWithoutExt.replace(/^\d+[\s_-]+/, '');

  // Replace remaining underscores and hyphens with spaces
  const altText = withoutPrefix.replace(/[_-]+/g, ' ');

  return altText;
}

/**
 * Sort filenames using natural numeric order
 * Examples:
 *   ["10_image.jpg", "2_image.jpg", "1_image.jpg"] → ["1_image.jpg", "2_image.jpg", "10_image.jpg"]
 */
function sortFilenamesNumerically(filenames: string[]): string[] {
  return [...filenames].sort((a, b) =>
    a.localeCompare(b, 'en', { numeric: true })
  );
}

/**
 * Generate unique hotspot IDs
 * Example: generateHotspotId("podorys", 0) → "hotspot-podorys-0"
 */
function generateHotspotId(imageName: string, index: number): string {
  return `hotspot-${imageName}-${index}`;
}

/**
 * Discover and load images from a folder using import.meta.glob()
 * Returns array of ImageItem objects ready for rendering
 */
async function discoverImages(folderPath: string) {
  // Discover JPG files
  const imageModules = import.meta.glob<{ default: any }>(
    '../../assets/galleries/**/*.jpg',
    { eager: true }
  );

  // Discover YAML files for hotspots
  const yamlModules = import.meta.glob<string>(
    '../../assets/galleries/**/*.yaml',
    { eager: true, as: 'raw' }
  );

  // Filter images and YAML to matching folder using regex-based path boundary check
  const folderName = folderPath.split('/').pop() || '';
  const folderRegex = new RegExp(`galleries/${folderName}/.*\\.jpg$`);
  const yamlRegex = new RegExp(`galleries/${folderName}/.*\\.yaml$`);

  const matchingImages = Object.entries(imageModules)
    .filter(([path]) => folderRegex.test(path))
    .map(([path, module]) => ({
      path,
      filename: path.split('/').pop() || '',
      src: module.default
    }));

  // Create map of YAML data by image filename (without extension)
  const yamlDataMap: Record<string, any> = {};
  Object.entries(yamlModules)
    .filter(([path]) => yamlRegex.test(path))
    .forEach(([path, content]) => {
      try {
        const yamlFilename = path.split('/').pop() || '';
        const imageFilename = yamlFilename.replace(/\.yaml$/, '');
        yamlDataMap[imageFilename] = parseYaml(content);
      } catch (error) {
        console.warn(`Failed to parse YAML at ${path}:`, error);
      }
    });

  // Sort images numerically with O(1) lookup using a map
  const imageMap = new Map(matchingImages.map(img => [img.filename, img]));
  const sortedImages = sortFilenamesNumerically(
    matchingImages.map(img => img.filename)
  ).map(filename => imageMap.get(filename)!);

  // Build ImageItem array with hotspots and optimized URLs for lightbox
  const images = await Promise.all(sortedImages.map(async (img) => {
    const imageName = img.filename.replace(/\.[^/.]+$/, '');
    const yamlData = yamlDataMap[imageName];

    let hotspots: Hotspot[] = [];
    if (yamlData?.hotspots && Array.isArray(yamlData.hotspots)) {
      hotspots = yamlData.hotspots.map((hotspot: any, idx: number) => ({
        id: generateHotspotId(imageName, idx),
        label: hotspot.label || '',
        x: hotspot.x || 0,
        y: hotspot.y || 0,
        href: hotspot.href
      }));
    }

    // Get the optimized image using getImage()
    const optimized = await getImage({ src: img.src });

    return {
      src: img.src,
      alt: generateAltText(img.filename),
      hotspots: hotspots.length > 0 ? hotspots : undefined,
      lightboxSrc: optimized.src
    };
  }));

  return images;
}

/**
 * Gallery component for displaying image collections
 *
 * Auto-discovers images from a folder using import.meta.glob() at build time.
 *
 * Expects folder structure:
 *   src/assets/galleries/{name}/
 *     ├── 1_image-name.jpg
 *     ├── 1_image-name.yaml (optional, for hotspots)
 *     └── ...
 *
 * Alt text is generated from filename: "1_podorys.jpg" → "podorys"
 * Hotspots loaded from YAML sidecar files if present.
 */

const { folder } = Astro.props;

let images: ImageItem[] = [];
if (folder) {
  try {
    images = await discoverImages(folder);
  } catch (error) {
    console.error(`Failed to discover images in folder ${folder}:`, error);
  }
}

const isEmpty = !images[0];
const isMultiple = images.length > 1;
---

<div class="gallery-container" data-gallery data-gallery-container>
  {isEmpty ? (
    <div class="flex items-center justify-center w-full bg-gray-100 rounded-lg p-8 min-h-64">
      <p class="text-gray-500 text-center">No images available in this gallery</p>
    </div>
  ) : isMultiple ? (
    <>
      {/* Main Image Container - render all images, show based on selection */}
      <div class="relative w-full" data-main-images>
        {images.map((img, idx) => (
          <div data-image-index={idx} class={idx === 0 ? '' : 'hidden'}>
            <a
              href={img.lightboxSrc}
              data-glightbox="gallery"
              class="inline-block w-full text-decoration-none cursor-pointer"
              style="all: inherit;"
            >
              <HotspotImage
                image={img.src}
                alt={img.alt}
                hotspots={img.hotspots || []}
              />
            </a>
          </div>
        ))}
      </div>

      {/* Thumbnail Strip */}
      <div class="overflow-x-auto py-4 px-2 bg-gray-100">
        <div class="flex gap-3 min-w-max">
          {images.map((img, idx) => (
            <button
              class={`flex-shrink-0 h-24 w-24 rounded-lg overflow-hidden border-2 transition-colors cursor-pointer ${
                idx === 0 ? 'border-amber' : 'border-wood hover:border-amber'
              }`}
              data-thumbnail={idx}
              aria-label={`View image ${idx + 1}`}
            >
              <Image src={img.src} alt={img.alt} class="w-full h-full object-cover" loading="lazy" />
            </button>
          ))}
        </div>
      </div>
    </>
  ) : (
    <>
      {/* Single Image */}
      {images[0] && (
        <a
          href={images[0].lightboxSrc}
          data-glightbox
          class="inline-block w-full text-decoration-none cursor-pointer"
          style="all: inherit;"
        >
          <HotspotImage
            image={images[0].src}
            alt={images[0].alt}
            hotspots={images[0].hotspots || []}
          />
        </a>
      )}
    </>
  )}
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
<script src="https://cdn.jsdelivr.net/npm/glightbox"></script>

<script is:inline>
  console.log('Gallery script initializing...');

  // Wait for DOM and GLightbox to be ready
  function initGallery() {
    console.log('initGallery called');
    console.log('GLightbox global:', typeof GLightbox, GLightbox);

    // Initialize GLightbox with debug logging
    const lightbox = GLightbox({
      selector: '[data-glightbox]',
      onOpen: () => console.log('GLightbox: onOpen event fired'),
      onClose: () => console.log('GLightbox: onClose event fired'),
    });
    console.log('GLightbox initialized:', lightbox);
    console.log('GLightbox version:', lightbox.version?.());

    // Prevent default link behavior and let GLightbox handle it
    const glightboxLinks = document.querySelectorAll('[data-glightbox]');
    console.log('Found data-glightbox elements:', glightboxLinks.length);

    // Preload all images as blob URLs for GLightbox
    glightboxLinks.forEach((link, idx) => {
      const href = link.getAttribute('href');
      console.log(`Preloading glightbox image ${idx}: ${href}`);

      fetch(href)
        .then(r => r.blob())
        .then(blob => {
          console.log(`  Image ${idx} preloaded: ${blob.size} bytes`);
          // Create a blob URL that GLightbox can actually load
          const blobUrl = URL.createObjectURL(blob);
          link.setAttribute('href', blobUrl);
          link.setAttribute('data-blob-url', 'true');
          console.log(`  Image ${idx} blob URL ready for GLightbox`);
        })
        .catch(e => console.error(`  Image ${idx} preload error:`, e.name, e.message));

      link.addEventListener('click', (e) => {
        console.log(`GLightbox link ${idx} clicked!`);
        e.preventDefault();
        console.log('  calling lightbox.open()');
        lightbox.open(link);
      });
    });

    // Thumbnail navigation - swap visible image and update styles
    const galleries = document.querySelectorAll('[data-gallery-container]');
    console.log('Found data-gallery-container elements:', galleries.length);

    galleries.forEach((gallery, gIdx) => {
      const mainImages = gallery.querySelector('[data-main-images]');
      const thumbnails = gallery.querySelectorAll('[data-thumbnail]');

      console.log(`Gallery ${gIdx}: found ${thumbnails.length} thumbnails`);

      thumbnails.forEach((thumb, index) => {
        console.log(`Attaching click handler to thumbnail ${index}`);
        thumb.addEventListener('click', () => {
          console.log(`Thumbnail ${index} clicked!`);
          // Update thumbnail border colors
          thumbnails.forEach((t, i) => {
            if (i === index) {
              t.classList.remove('border-wood');
              t.classList.add('border-amber');
            } else {
              t.classList.add('border-wood');
              t.classList.remove('border-amber');
            }
          });

          // Show selected image, hide others
          if (mainImages) {
            mainImages.querySelectorAll('[data-image-index]').forEach((imgDiv, i) => {
              if (i === index) {
                imgDiv.classList.remove('hidden');
              } else {
                imgDiv.classList.add('hidden');
              }
            });
          }
        });
      });
    });
  }

  // Run when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGallery);
  } else {
    initGallery();
  }
</script>
