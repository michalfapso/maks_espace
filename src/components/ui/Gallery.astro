---
// src/components/ui/Gallery.astro
import { Image, getImage } from 'astro:assets';
import HotspotImage from './HotspotImage.astro';
import { parse as parseYaml } from 'yaml';
import type { Hotspot } from './HotspotImage.astro';
import { computeContainerAR, computeOverlay } from '../../utils/gallery';

interface Props {
  folder: string; // e.g., 'src/assets/galleries/1'
}

interface ImageItem {
  src: any;
  alt: string;
  hotspots?: Hotspot[];
  lightboxSrc?: string;
  overlayTop: number;
  overlayLeft: number;
  overlayHeight: number;
  overlayWidth: number;
}

/**
 * Generate alt text from filename by stripping numeric prefix and separators
 * Examples:
 *   "1_podorys.jpg" → "podorys"
 *   "3-bedroom-view.jpg" → "bedroom view"
 *   "image.jpg" → "image"
 */
function generateAltText(filename: string): string {
  // Remove file extension
  const nameWithoutExt = filename.replace(/\.[^/.]+$/, '');

  // Strip leading digits and separators (_, -, space)
  const withoutPrefix = nameWithoutExt.replace(/^\d+[\s_-]+/, '');

  // Replace remaining underscores and hyphens with spaces
  const altText = withoutPrefix.replace(/[_-]+/g, ' ');

  return altText;
}

/**
 * Sort filenames using natural numeric order
 * Examples:
 *   ["10_image.jpg", "2_image.jpg", "1_image.jpg"] → ["1_image.jpg", "2_image.jpg", "10_image.jpg"]
 */
function sortFilenamesNumerically(filenames: string[]): string[] {
  return [...filenames].sort((a, b) =>
    a.localeCompare(b, 'en', { numeric: true })
  );
}

/**
 * Generate unique hotspot IDs
 * Example: generateHotspotId("podorys", 0) → "hotspot-podorys-0"
 */
function generateHotspotId(imageName: string, index: number): string {
  return `hotspot-${imageName}-${index}`;
}

/**
 * Discover and load images from a folder using import.meta.glob()
 * Returns array of ImageItem objects ready for rendering
 */
async function discoverImages(folderPath: string): Promise<{ images: ImageItem[], containerAR: number }> {
  // Discover JPG files
  const imageModules = import.meta.glob<{ default: any }>(
    '../../assets/galleries/**/*.jpg',
    { eager: true }
  );

  // Discover YAML files for hotspots
  const yamlModules = import.meta.glob<string>(
    '../../assets/galleries/**/*.yaml',
    { eager: true, as: 'raw' }
  );

  // Filter images and YAML to matching folder using regex-based path boundary check
  const folderName = folderPath.split('/').pop() || '';
  const folderRegex = new RegExp(`galleries/${folderName}/.*\\.jpg$`);
  const yamlRegex = new RegExp(`galleries/${folderName}/.*\\.yaml$`);

  const matchingImages = Object.entries(imageModules)
    .filter(([path]) => folderRegex.test(path))
    .map(([path, module]) => ({
      path,
      filename: path.split('/').pop() || '',
      src: module.default
    }));

  // Create map of YAML data by image filename (without extension)
  const yamlDataMap: Record<string, any> = {};
  Object.entries(yamlModules)
    .filter(([path]) => yamlRegex.test(path))
    .forEach(([path, content]) => {
      try {
        const yamlFilename = path.split('/').pop() || '';
        const imageFilename = yamlFilename.replace(/\.yaml$/, '');
        yamlDataMap[imageFilename] = parseYaml(content);
      } catch (error) {
        console.warn(`Failed to parse YAML at ${path}:`, error);
      }
    });

  // Sort images numerically with O(1) lookup using a map
  const imageMap = new Map(matchingImages.map(img => [img.filename, img]));
  const sortedImages = sortFilenamesNumerically(
    matchingImages.map(img => img.filename)
  ).map(filename => imageMap.get(filename)!);

  // Build ImageItem array with hotspots and optimized URLs for lightbox
  const images = await Promise.all(sortedImages.map(async (img) => {
    const imageName = img.filename.replace(/\.[^/.]+$/, '');
    const yamlData = yamlDataMap[imageName];

    let hotspots: Hotspot[] = [];
    if (yamlData?.hotspots && Array.isArray(yamlData.hotspots)) {
      hotspots = yamlData.hotspots.map((hotspot: any, idx: number) => ({
        id: generateHotspotId(imageName, idx),
        label: hotspot.label || '',
        x: hotspot.x || 0,
        y: hotspot.y || 0,
        href: hotspot.href
      }));
    }

    // Get the optimized image using getImage()
    const optimized = await getImage({ src: img.src });

    return {
      src: img.src,
      alt: generateAltText(img.filename),
      hotspots: hotspots.length > 0 ? hotspots : undefined,
      lightboxSrc: optimized.src,
      overlayTop: 0,
      overlayLeft: 0,
      overlayHeight: 1,
      overlayWidth: 1
    };
  }));

  const heightRatios = images.map(img => img.src.height / img.src.width);
  const containerAR = computeContainerAR(heightRatios);

  const imagesWithOverlay: ImageItem[] = images.map(img => {
    const imageAR = img.src.width / img.src.height;
    return { ...img, ...computeOverlay(imageAR, containerAR) };
  });

  return { images: imagesWithOverlay, containerAR };
}

/**
 * Gallery component for displaying image collections
 *
 * Auto-discovers images from a folder using import.meta.glob() at build time.
 *
 * Expects folder structure:
 *   src/assets/galleries/{name}/
 *     ├── 1_image-name.jpg
 *     ├── 1_image-name.yaml (optional, for hotspots)
 *     └── ...
 *
 * Alt text is generated from filename: "1_podorys.jpg" → "podorys"
 * Hotspots loaded from YAML sidecar files if present.
 */

const { folder } = Astro.props;

let images: ImageItem[] = [];
let containerAR = 1;
if (folder) {
  try {
    ({ images, containerAR } = await discoverImages(folder));
  } catch (error) {
    console.error(`Failed to discover images in folder ${folder}:`, error);
  }
}

const isEmpty = !images[0];
const isMultiple = images.length > 1;
---

<div class="gallery-container" data-gallery data-gallery-container>
  {isEmpty ? (
    <div class="flex items-center justify-center w-full bg-gray-100 rounded-lg p-8 min-h-64">
      <p class="text-gray-500 text-center">No images available in this gallery</p>
    </div>
  ) : isMultiple ? (
    <>
      {/* Main Image Container - render all images, show based on selection */}
      <div class="relative w-full" data-main-images style={`aspect-ratio: ${containerAR};`}>
        {images.map((img, idx) => (
          <div data-image-index={idx} class={`w-full h-full ${idx === 0 ? '' : 'hidden'}`}>
            <a
              href={img.lightboxSrc}
              data-glightbox="type: image"
              style="all: inherit;"
            >
              <HotspotImage
                image={img.src}
                alt={img.alt}
                hotspots={img.hotspots || []}
                overlayTop={img.overlayTop}
                overlayLeft={img.overlayLeft}
                overlayHeight={img.overlayHeight}
                overlayWidth={img.overlayWidth}
              />
            </a>
          </div>
        ))}
      </div>

      {/* Thumbnail Strip */}
      <div class="overflow-x-auto py-4 px-2 bg-gray-100">
        <div class="flex gap-3 min-w-max">
          {images.map((img, idx) => (
            <button
              class={`flex-shrink-0 h-24 w-24 rounded-lg overflow-hidden border-2 transition-colors cursor-pointer ${
                idx === 0 ? 'border-amber' : 'border-wood hover:border-amber'
              }`}
              data-thumbnail={idx}
              aria-label={`View image ${idx + 1}`}
            >
              <Image src={img.src} alt={img.alt} class="w-full h-full object-cover" loading="lazy" />
            </button>
          ))}
        </div>
      </div>
    </>
  ) : (
    <>
      {/* Single Image */}
      {images[0] && (
        <div class="relative w-full" style={`aspect-ratio: ${containerAR};`}>
          <a
            href={images[0].lightboxSrc}
            data-glightbox="type: image"
            style="all: inherit;"
          >
            <HotspotImage
              image={images[0].src}
              alt={images[0].alt}
              hotspots={images[0].hotspots || []}
              overlayTop={images[0].overlayTop}
              overlayLeft={images[0].overlayLeft}
              overlayHeight={images[0].overlayHeight}
              overlayWidth={images[0].overlayWidth}
            />
          </a>
        </div>
      )}
    </>
  )}
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
<script src="https://cdn.jsdelivr.net/npm/glightbox"></script>

<script is:inline>
  function initGallery() {
    GLightbox({ selector: '[data-glightbox]' });

    let lastHotspotOverlay = null;

    // Track hotspots when glightbox link is clicked
    document.querySelectorAll('[data-glightbox]').forEach(glightboxLink => {
      glightboxLink.addEventListener('click', (e) => {
        // Find the parent hotspot container
        const hotspotContainer = glightboxLink.querySelector('[data-hotspot-image]');

        // Prevent lightbox if popup is active or was just closed (200ms debounce)
        if (hotspotContainer) {
          const isOpen = hotspotContainer.hasAttribute('data-popup-open');
          const closedAtStr = hotspotContainer.getAttribute('data-popup-just-closed');
          const closedAt = parseInt(closedAtStr || '0', 10);
          const recentlyClosed = closedAt > 0 && (Date.now() - closedAt < 200);
          if (isOpen || recentlyClosed) {
            e.preventDefault();
            // If clicking a hotspot button, let the event continue so the button's
            // own click handler (which calls stopPropagation in bubble phase) can fire.
            // If clicking elsewhere, we must stopPropagation ourselves to block GLightbox.
            if (!e.target.closest('[data-hotspot-id]')) {
              e.stopPropagation();
            }
            return;
          }
        }

        // Lightbox will open — store overlay and schedule hotspot injection
        lastHotspotOverlay = hotspotContainer?.querySelector('[class*="absolute"][style*="left"]');
        setTimeout(() => {
          injectHotspotsIntoLightbox(lastHotspotOverlay);
        }, 200);
      }, true); // Use capture phase
    });

    function injectHotspotsIntoLightbox(overlay) {
      if (!overlay) return;

      const glightbox = document.querySelector('.glightbox-container');
      if (!glightbox || glightbox.style.display === 'none') return;

      const activeSlide = glightbox.querySelector('.gslide');
      if (!activeSlide || activeSlide.querySelector('[data-hotspots-lightbox]')) return;

      // Clone the hotspots overlay
      const clonedOverlay = overlay.cloneNode(true);
      clonedOverlay.setAttribute('data-hotspots-lightbox', 'true');

      // Remove popups from clone
      clonedOverlay.querySelectorAll('[data-hotspot-popup]').forEach(popup => popup.remove());

      // Append to the slide
      const slideMedia = activeSlide.querySelector('.gslide-media') || activeSlide;
      slideMedia.style.position = 'relative';
      slideMedia.appendChild(clonedOverlay);

      // Initialize hotspot handlers in lightbox
      const buttons = clonedOverlay.querySelectorAll('[data-hotspot-id]');
      buttons.forEach(button => {
        button.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();

          const label = button.getAttribute('data-hotspot-label') || '';
          const href = button.getAttribute('data-hotspot-href');
          const hasPrice = button.getAttribute('data-hotspot-price') === 'true';

          // Remove existing popups for this button
          clonedOverlay.querySelectorAll('[data-lightbox-popup]').forEach(p => p.remove());

          // Create popup
          const popup = document.createElement('div');
          popup.setAttribute('data-lightbox-popup', 'true');
          popup.className = 'absolute bg-white/95 backdrop-blur rounded-lg shadow-xl p-4 max-w-xs pointer-events-auto';
          popup.style.left = button.offsetLeft + 'px';
          popup.style.top = (button.offsetTop - 100) + 'px';
          popup.style.transform = 'translateX(-50%)';
          popup.style.zIndex = '1000';

          // Create content
          let content;
          if (hasPrice && href) {
            content = document.createElement('a');
            content.href = href;
            content.className = 'block text-amber font-semibold hover:underline';
            content.textContent = label;
          } else if (href) {
            content = document.createElement('a');
            content.href = href;
            content.className = 'text-amber font-semibold hover:underline';
            content.textContent = label;
          } else {
            content = document.createElement('p');
            content.className = 'text-gray-800';
            content.textContent = label;
          }

          popup.appendChild(content);
          clonedOverlay.appendChild(popup);

          // Close on outside click
          const closeHandler = (e) => {
            if (!popup.contains(e.target) && !button.contains(e.target)) {
              popup.remove();
              document.removeEventListener('click', closeHandler);
            }
          };
          document.addEventListener('click', closeHandler);
        });
      });
    }

    // Thumbnail navigation - swap visible image and update border styles
    document.querySelectorAll('[data-gallery-container]').forEach((gallery) => {
      const mainImages = gallery.querySelector('[data-main-images]');
      const thumbnails = gallery.querySelectorAll('[data-thumbnail]');

      thumbnails.forEach((thumb, index) => {
        thumb.addEventListener('click', () => {
          thumbnails.forEach((t, i) => {
            t.classList.toggle('border-wood', i !== index);
            t.classList.toggle('border-amber', i === index);
          });
          if (mainImages) {
            mainImages.querySelectorAll('[data-image-index]').forEach((imgDiv, i) => {
              imgDiv.classList.toggle('hidden', i !== index);
            });
          }
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGallery);
  } else {
    initGallery();
  }
</script>
