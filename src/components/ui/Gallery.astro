---
// src/components/ui/Gallery.astro
import { Image } from 'astro:assets';
import HotspotImage from './HotspotImage.astro';

interface Props {
  folder: string; // e.g., 'src/assets/galleries/1'
}

interface ImageItem {
  src: any;  // ImageMetadata, but avoid strict mode issue with component-wide any for now
  alt: string;
  hotspots?: any[];  // Array of Hotspot if available
}

/**
 * Gallery component for displaying image collections
 *
 * Currently expects images to be passed as an array with structure:
 * { src: ImageMetadata, alt: string, hotspots?: Hotspot[] }
 *
 * Future: Will support auto-discovery via folder + import.meta.glob()
 * The 'folder' prop is reserved for future use with dynamic image loading
 */

const { folder } = Astro.props;

// Auto-discover images (simplified - production version would use import.meta.glob)
// For now, pass images as children or define manually per page
const images: ImageItem[] = [];

const currentImage = images[0];
const isEmpty = !currentImage;
const isMultiple = images.length > 1;

const renderImage = () => {
  if (!currentImage) return null;
  if (currentImage?.hotspots) {
    return (
      <HotspotImage
        image={currentImage.src}
        alt={currentImage.alt}
        hotspots={currentImage.hotspots}
      />
    );
  }
  return <Image src={currentImage.src} alt={currentImage.alt} class="w-full h-auto" />;
};
---

<div class="gallery-container" data-gallery>
  {isEmpty ? (
    <div class="flex items-center justify-center w-full bg-gray-100 rounded-lg p-8 min-h-64">
      <p class="text-gray-500 text-center">No images available in this gallery</p>
    </div>
  ) : isMultiple ? (
    <>
      {/* Main Image */}
      <div class="relative w-full">
        {renderImage()}
      </div>

      {/* Thumbnail Strip */}
      <div class="overflow-x-auto py-4 px-2 bg-gray-100">
        <div class="flex gap-3 min-w-max">
          {images.map((img, idx) => (
            <button
              class={`flex-shrink-0 h-24 w-24 rounded-lg overflow-hidden border-2 transition-colors cursor-pointer ${
                idx === 0 ? 'border-amber' : 'border-wood hover:border-amber'
              }`}
              data-thumbnail={idx}
              aria-label={`View image ${idx + 1}`}
            >
              <Image src={img.src} alt={img.alt} class="w-full h-full object-cover" loading="lazy" />
            </button>
          ))}
        </div>
      </div>
    </>
  ) : (
    <>
      {/* Single Image */}
      {renderImage()}
    </>
  )}
</div>

<script>
  // Thumbnail navigation
  document.querySelectorAll('[data-gallery]').forEach(gallery => {
    const thumbnails = gallery.querySelectorAll('[data-thumbnail]');
    thumbnails.forEach((thumb, index) => {
      thumb.addEventListener('click', () => {
        thumbnails.forEach((t, i) => {
          if (i === index) {
            t.classList.remove('border-wood');
            t.classList.add('border-amber');
          } else {
            t.classList.add('border-wood');
            t.classList.remove('border-amber');
          }
        });
      });
    });
  });
</script>
