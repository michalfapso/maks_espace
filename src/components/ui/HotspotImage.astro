---
// src/components/ui/HotspotImage.astro
import { Image, type ImageMetadata } from 'astro:assets';

export interface Hotspot {
  id: string;
  x: number;
  y: number;
  label: string;
  href?: string;
}

interface Props {
  image: ImageMetadata;
  alt: string;
  hotspots: Hotspot[];
  overlayTop?: number;
  overlayLeft?: number;
  overlayHeight?: number;
  overlayWidth?: number;
}

const {
  image,
  alt,
  hotspots,
  overlayTop = 0,
  overlayLeft = 0,
  overlayHeight = 1,
  overlayWidth = 1,
} = Astro.props;
const hasPrice = (label: string) => /€|\d+.*€/.test(label);
---

<div class="relative w-full h-full" data-hotspot-image>
  <Image src={image} alt={alt} class="w-full h-full object-contain" loading="lazy" />

  {/* Hotspot Dots */}
  <div
    class="absolute"
    style={`top: ${overlayTop * 100}%; left: ${overlayLeft * 100}%; width: ${overlayWidth * 100}%; height: ${overlayHeight * 100}%;`}
  >
    {hotspots.map(hotspot => (
      <button
        class="group absolute w-6 h-6 -translate-x-1/2 -translate-y-1/2 cursor-pointer bg-transparent border-0 p-0"
        style={`left: ${hotspot.x}%; top: ${hotspot.y}%;`}
        data-hotspot-id={hotspot.id}
        data-hotspot-label={hotspot.label}
        data-hotspot-href={hotspot.href || ''}
        data-hotspot-price={hasPrice(hotspot.label) ? 'true' : 'false'}
        aria-label={`Hotspot: ${hotspot.label}`}
      >
        {/* Outer white border layer */}
        <span class="absolute inset-0 rounded-full border-2 border-white"></span>
        {/* Middle black background layer with hover opacity transition */}
        <span class="absolute inset-1 rounded-full bg-black/70 transition-opacity duration-200 group-hover:opacity-90"></span>
        {/* Inner white dot layer that shrinks on hover */}
        <span class="absolute inset-6 rounded-full bg-white transition-all duration-200 group-hover:inset-8"></span>
      </button>
    ))}
  </div>

  {/* Popup Container */}
  <div class="absolute pointer-events-none opacity-0 transition-opacity duration-200" data-hotspot-popup>
    <div class="bg-white/95 backdrop-blur rounded-lg shadow-xl p-4 max-w-xs pointer-events-auto" data-popup-content></div>
  </div>
</div>

<script>
  document.querySelectorAll('[data-hotspot-image]').forEach(container => {
    const buttons = container.querySelectorAll('[data-hotspot-id]');
    const popup = container.querySelector('[data-hotspot-popup]');
    const popupContent = container.querySelector('[data-popup-content]');

    buttons.forEach(button => {
      button.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        // Debug: check the hotspot structure (Issue 3)
        console.log('Hotspot clicked:', {
          id: button.getAttribute('data-hotspot-id'),
          children: button.children.length,
          childClasses: Array.from(button.children).map(c => c.className),
        });

        const label = button.getAttribute('data-hotspot-label') || '';
        const href = button.getAttribute('data-hotspot-href');
        const hasPrice = button.getAttribute('data-hotspot-price') === 'true';

        popupContent.innerHTML = '';

        let element;
        if (hasPrice && href) {
          element = document.createElement('a');
          element.href = href;
          element.className = 'block text-amber font-semibold hover:underline';
          element.textContent = label;
        } else if (href) {
          element = document.createElement('a');
          element.href = href;
          element.className = 'text-amber font-semibold hover:underline';
          element.textContent = label;
        } else {
          element = document.createElement('p');
          element.className = 'text-gray-800';
          element.textContent = label;
        }

        popupContent.appendChild(element);

        const x = button.offsetLeft;
        let y = button.offsetTop - 100;
        if (y < 0) y = button.offsetTop + 30;

        popup.style.left = x + 'px';
        popup.style.top = y + 'px';
        popup.style.transform = 'translateX(-50%)';
        popup.classList.add('active');
        container.setAttribute('data-popup-open', 'true');

        // Calculate hotspot position as percentage of image (for transform-origin)
        const containerRect = container.getBoundingClientRect();
        const buttonRect = button.getBoundingClientRect();
        const hotspotCenterX = ((buttonRect.left - containerRect.left) / containerRect.width) * 100;
        const hotspotCenterY = ((buttonRect.top - containerRect.top) / containerRect.height) * 100;

        // Apply zoom with hotspot as origin (Issue 2: also apply to hotspots overlay)
        const img = container.querySelector('img');
        const hotspotsOverlay = container.querySelector('[class*="absolute"]'); // Gets the overlay div with hotspots
        if (img) {
          img.style.transformOrigin = `${hotspotCenterX}% ${hotspotCenterY}%`;
          img.classList.add('hotspot-zoom');
        }
        // Apply same zoom to hotspots container so they scale with image
        if (hotspotsOverlay && hotspotsOverlay.firstChild) {
          hotspotsOverlay.style.transform = `scale(1.1)`;
          hotspotsOverlay.style.transformOrigin = `${hotspotCenterX}% ${hotspotCenterY}%`;
          hotspotsOverlay.style.transition = 'transform 0.3s ease';
        }
      });
    });

    const controller = new AbortController();

    document.addEventListener('click', (e) => {
      const popupActive = popup.classList.contains('active');
      // Debug: log click event flow (Issue 1)
      console.log('Click event:', {
        target: e.target.tagName,
        popupActive,
        popupContains: popup.contains(e.target),
        containerContains: container.contains(e.target),
      });

      // Don't close popup if clicking inside the popup
      if (popup.contains(e.target)) {
        console.log('Click on popup content - staying open');
        return;
      }
      // Prevent lightbox from opening when closing popup
      if (popupActive) {
        console.log('Popup was active, stopping propagation to prevent lightbox');
        e.stopPropagation();
      }
      // Close popup on any other click (inside or outside container)
      popup.classList.remove('active');
      container.removeAttribute('data-popup-open');

      // Remove zoom from image AND hotspots (Issue 2)
      const img = container.querySelector('img');
      const hotspotsOverlay = container.querySelector('[class*="absolute"]');
      if (img) {
        img.classList.remove('hotspot-zoom');
      }
      if (hotspotsOverlay) {
        hotspotsOverlay.style.transform = '';
        hotspotsOverlay.style.transformOrigin = '';
      }
    }, { signal: controller.signal });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        popup.classList.remove('active');
        container.removeAttribute('data-popup-open');

        // Remove zoom from image AND hotspots (Issue 2)
        const img = container.querySelector('img');
        const hotspotsOverlay = container.querySelector('[class*="absolute"]');
        if (img) {
          img.classList.remove('hotspot-zoom');
        }
        if (hotspotsOverlay) {
          hotspotsOverlay.style.transform = '';
          hotspotsOverlay.style.transformOrigin = '';
        }
      }
    }, { signal: controller.signal });
  });
</script>

<style>
  button[data-hotspot-id] {
    transition: filter 0.15s ease;
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    outline: none !important;
  }

  button[data-hotspot-id]:hover {
    filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.3));
  }

  button[data-hotspot-id]:focus {
    outline: none;
  }

  /* Outer white border layer */
  button[data-hotspot-id] > span:nth-child(1) {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    border: 2px solid white;
  }

  /* Middle black circle at 70% opacity */
  button[data-hotspot-id] > span:nth-child(2) {
    position: absolute;
    inset: 4px;
    border-radius: 9999px;
    background-color: rgba(0, 0, 0, 0.7);
    transition: opacity 0.2s;
  }

  button[data-hotspot-id]:hover > span:nth-child(2) {
    opacity: 0.9;
  }

  /* Inner white dot layer that shrinks on hover */
  button[data-hotspot-id] > span:nth-child(3) {
    position: absolute;
    inset: 24px;
    border-radius: 9999px;
    background-color: white;
    transition: inset 0.2s;
  }

  button[data-hotspot-id]:hover > span:nth-child(3) {
    inset: 20px;
  }

  [data-hotspot-image] > img.hotspot-zoom {
    transform: scale(1.1);
    transition: transform 0.3s ease;
  }
</style>
