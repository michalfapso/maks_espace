---
// src/components/ui/HotspotImage.astro
import { Image, type ImageMetadata } from 'astro:assets';

export interface Hotspot {
  id: string;
  x: number;
  y: number;
  label: string;
  href?: string;
}

interface Props {
  image: ImageMetadata;
  alt: string;
  hotspots: Hotspot[];
  overlayTop?: number;
  overlayLeft?: number;
  overlayHeight?: number;
  overlayWidth?: number;
}

const {
  image,
  alt,
  hotspots,
  overlayTop = 0,
  overlayLeft = 0,
  overlayHeight = 1,
  overlayWidth = 1,
} = Astro.props;
const hasPrice = (label: string) => /€|\d+.*€/.test(label);
---

<div class="relative w-full h-full overflow-hidden" data-hotspot-image>
  <Image src={image} alt={alt} class="w-full h-full object-contain" loading="lazy" />

  {/* Hotspot Dots */}
  <div
    class="absolute"
    style={`top: ${overlayTop * 100}%; left: ${overlayLeft * 100}%; width: ${overlayWidth * 100}%; height: ${overlayHeight * 100}%;`}
  >
    {hotspots.map(hotspot => (
      <button
        class="group absolute w-6 h-6 -translate-x-1/2 -translate-y-1/2 cursor-pointer bg-transparent border-0 p-0"
        style={`left: ${hotspot.x}%; top: ${hotspot.y}%;`}
        data-hotspot-id={hotspot.id}
        data-hotspot-label={hotspot.label}
        data-hotspot-href={hotspot.href || ''}
        data-hotspot-price={hasPrice(hotspot.label) ? 'true' : 'false'}
        aria-label={`Hotspot: ${hotspot.label}`}
      >
        {/* Outer white border layer: fills entire button */}
        <span class="absolute rounded-full border-2 border-white"></span>
        {/* Middle black background layer: positioned with CSS for percentage inset */}
        <span class="absolute rounded-full transition-opacity duration-500 bg-black/50"></span>
        {/* Inner white dot layer: positioned with CSS for percentage inset, shrinks on hover */}
        <span class="absolute rounded-full bg-white transition-all duration-500"></span>
      </button>
    ))}
  </div>

  {/* Individual Popup Containers */}
  {hotspots.map(hotspot => (
    <div
      class="absolute pointer-events-none opacity-0 transition-opacity duration-500"
      data-hotspot-popup-id={hotspot.id}
    >
      <div class="bg-white/95 backdrop-blur rounded-lg shadow-xl p-4 max-w-xs pointer-events-auto" data-popup-content></div>
    </div>
  ))}
</div>

<script>
  document.querySelectorAll('[data-hotspot-image]').forEach(container => {
    const buttons = container.querySelectorAll('[data-hotspot-id]');
    const popups = container.querySelectorAll('[data-hotspot-popup-id]');

    // Create a map of hotspot ID to popup and button
    const hotspotsMap = new Map();
    buttons.forEach(button => {
      const id = button.getAttribute('data-hotspot-id');
      const popup = container.querySelector(`[data-hotspot-popup-id="${id}"]`);
      hotspotsMap.set(id, { button, popup });
    });

    // Helper to hide all popups
    const hideAllPopups = () => {
      popups.forEach(popup => {
        popup.classList.remove('opacity-100');
      });
      container.removeAttribute('data-popup-open');
    };

    // Helper to show a popup
    const showPopup = (hotspotId, isAnimating = false) => {
      const { button, popup } = hotspotsMap.get(hotspotId);
      const popupContent = popup.querySelector('[data-popup-content]');

      const label = button.getAttribute('data-hotspot-label') || '';
      const href = button.getAttribute('data-hotspot-href');
      const hasPrice = button.getAttribute('data-hotspot-price') === 'true';

      // Build content element
      let element;
      if (hasPrice && href) {
        element = document.createElement('a');
        element.href = href;
        element.className = 'block text-amber font-semibold hover:underline';
        element.textContent = label;
      } else if (href) {
        element = document.createElement('a');
        element.href = href;
        element.className = 'text-amber font-semibold hover:underline';
        element.textContent = label;
      } else {
        element = document.createElement('p');
        element.className = 'text-gray-800';
        element.textContent = label;
      }

      popupContent.innerHTML = '';
      popupContent.appendChild(element);

      // Position popup
      const x = button.offsetLeft;
      let y = button.offsetTop - 100;
      if (y < 0) y = button.offsetTop + 30;

      popup.style.left = x + 'px';
      popup.style.top = y + 'px';
      popup.style.transform = 'translateX(-50%)';

      // Show this popup with fade in
      popup.classList.add('opacity-100');
      container.setAttribute('data-popup-open', 'true');
    };

    // Click handlers for buttons
    buttons.forEach(button => {
      button.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        const hotspotId = button.getAttribute('data-hotspot-id');
        const isAlreadyShowing = container.hasAttribute('data-popup-open');

        if (isAlreadyShowing) {
          // Parallel crossfade: fade out all others, fade in this one
          popups.forEach(popup => {
            popup.classList.remove('opacity-100');
          });
        }

        // Show the new popup
        showPopup(hotspotId, isAlreadyShowing);
      });
    });

    // Click outside to close
    const controller = new AbortController();

    document.addEventListener('click', (e) => {
      // Check if click is on any popup
      let clickedOnPopup = false;
      popups.forEach(popup => {
        if (popup.contains(e.target)) {
          clickedOnPopup = true;
        }
      });

      if (!clickedOnPopup && container.hasAttribute('data-popup-open')) {
        hideAllPopups();
        container.setAttribute('data-popup-just-closed', String(Date.now()));
      }
    }, { capture: true, signal: controller.signal });

    // Escape key to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && container.hasAttribute('data-popup-open')) {
        hideAllPopups();
        container.setAttribute('data-popup-just-closed', String(Date.now()));
      }
    }, { signal: controller.signal });
  });
</script>

<style>
  /* Button base styling */
  button[data-hotspot-id] {
    transition: filter 0.15s ease;
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    outline: none !important;
  }

  /* Remove unwanted pseudo-elements */
  button[data-hotspot-id]::after,
  button[data-hotspot-id]::before {
    display: none !important;
  }

  /* Button hover glow effect */
  button[data-hotspot-id]:hover {
    filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.3));
  }

  button[data-hotspot-id]:focus {
    outline: none;
  }

  /* Outer white border layer: fills entire button */
  button[data-hotspot-id] > span:nth-child(1) {
    inset: 0;
  }

  /* Middle black circle: 4% inset (~0.96px of 24px button, ~92% of parent size) */
  button[data-hotspot-id] > span:nth-child(2) {
    inset: 4%;
  }

  button[data-hotspot-id]:hover > span:nth-child(2) {
    opacity: 0.9;
  }

  /* Inner white dot: 28% inset at rest, shrinks to 10% on hover */
  button[data-hotspot-id] > span:nth-child(3) {
    inset: 28%;
  }

  button[data-hotspot-id]:hover > span:nth-child(3) {
    inset: 38%;
  }

  /* Popup visibility and animation */
  [data-hotspot-popup] {
    opacity: 0;
    pointer-events: none;
  }

  [data-hotspot-popup].active {
    opacity: 1;
    pointer-events: auto;
  }

</style>
