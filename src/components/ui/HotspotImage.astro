---
// src/components/ui/HotspotImage.astro
import { Image, type ImageMetadata } from 'astro:assets';

export interface Hotspot {
  id: string;
  x: number;
  y: number;
  label: string;
  href?: string;
}

interface Props {
  image: ImageMetadata;
  alt: string;
  hotspots: Hotspot[];
  overlayTop?: number;
  overlayLeft?: number;
  overlayHeight?: number;
  overlayWidth?: number;
}

const {
  image,
  alt,
  hotspots,
  overlayTop = 0,
  overlayLeft = 0,
  overlayHeight = 1,
  overlayWidth = 1,
} = Astro.props;
const hasPrice = (label: string) => /€|\d+.*€/.test(label);
---

<div class="relative w-full h-full overflow-hidden" data-hotspot-image>
  <Image src={image} alt={alt} class="w-full h-full object-contain" loading="lazy" />

  {/* Hotspot Dots */}
  <div
    class="absolute"
    style={`top: ${overlayTop * 100}%; left: ${overlayLeft * 100}%; width: ${overlayWidth * 100}%; height: ${overlayHeight * 100}%;`}
  >
    {hotspots.map(hotspot => (
      <button
        class="group absolute w-6 h-6 -translate-x-1/2 -translate-y-1/2 cursor-pointer bg-transparent border-0 p-0"
        style={`left: ${hotspot.x}%; top: ${hotspot.y}%;`}
        data-hotspot-id={hotspot.id}
        data-hotspot-label={hotspot.label}
        data-hotspot-href={hotspot.href || ''}
        data-hotspot-price={hasPrice(hotspot.label) ? 'true' : 'false'}
        aria-label={`Hotspot: ${hotspot.label}`}
      >
        {/* Outer white border layer: fills entire button */}
        <span class="absolute rounded-full border-2 border-white"></span>
        {/* Middle black background layer: positioned with CSS for percentage inset */}
        <span class="absolute rounded-full transition-opacity duration-200 bg-black/50"></span>
        {/* Inner white dot layer: positioned with CSS for percentage inset, shrinks on hover */}
        <span class="absolute rounded-full bg-white transition-all duration-500"></span>
      </button>
    ))}
  </div>

  {/* Popup Container */}
  <div class="absolute pointer-events-none opacity-0 transition-opacity duration-200" data-hotspot-popup>
    <div class="bg-white/95 backdrop-blur rounded-lg shadow-xl p-4 max-w-xs pointer-events-auto" data-popup-content></div>
  </div>
</div>

<script>
  document.querySelectorAll('[data-hotspot-image]').forEach(container => {
    const buttons = container.querySelectorAll('[data-hotspot-id]');
    const popup = container.querySelector('[data-hotspot-popup]');
    const popupContent = container.querySelector('[data-popup-content]');

    buttons.forEach(button => {
      button.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        const label = button.getAttribute('data-hotspot-label') || '';
        const href = button.getAttribute('data-hotspot-href');
        const hasPrice = button.getAttribute('data-hotspot-price') === 'true';

        popupContent.innerHTML = '';

        let element;
        if (hasPrice && href) {
          element = document.createElement('a');
          element.href = href;
          element.className = 'block text-amber font-semibold hover:underline';
          element.textContent = label;
        } else if (href) {
          element = document.createElement('a');
          element.href = href;
          element.className = 'text-amber font-semibold hover:underline';
          element.textContent = label;
        } else {
          element = document.createElement('p');
          element.className = 'text-gray-800';
          element.textContent = label;
        }

        popupContent.appendChild(element);

        const x = button.offsetLeft;
        let y = button.offsetTop - 100;
        if (y < 0) y = button.offsetTop + 30;

        popup.style.left = x + 'px';
        popup.style.top = y + 'px';
        popup.style.transform = 'translateX(-50%)';
        popup.classList.add('active');
        container.setAttribute('data-popup-open', 'true');

        // Calculate hotspot position as percentage of image (for transform-origin)
        const img = container.querySelector('img');
        const hotspotsOverlay = container.querySelector('[class*="absolute"][style*="left"]'); // Hotspots overlay with positioning

        if (img && hotspotsOverlay) {
          const containerRect = container.getBoundingClientRect();
          const buttonRect = button.getBoundingClientRect();
          const overlayRect = hotspotsOverlay.getBoundingClientRect();

          // Calculate transform-origin as percentage of the entire container (for image)
          const hotspotCenterX = ((buttonRect.left - containerRect.left) / containerRect.width) * 100;
          const hotspotCenterY = ((buttonRect.top - containerRect.top) / containerRect.height) * 100;

          // Calculate transform-origin relative to overlay container (for hotspots)
          const hotspotCenterXInOverlay = ((buttonRect.left - overlayRect.left) / overlayRect.width) * 100;
          const hotspotCenterYInOverlay = ((buttonRect.top - overlayRect.top) / overlayRect.height) * 100;

          // Apply zoom to image with origin at hotspot in container coordinates
          img.style.transformOrigin = `${hotspotCenterX}% ${hotspotCenterY}%`;
          img.classList.add('hotspot-zoom');

          // Apply zoom to hotspots overlay with origin at hotspot in overlay coordinates
          hotspotsOverlay.style.transform = `scale(1.1)`;
          hotspotsOverlay.style.transformOrigin = `${hotspotCenterXInOverlay}% ${hotspotCenterYInOverlay}%`;
          hotspotsOverlay.style.transition = 'transform 0.3s ease';
        }
      });
    });


    const controller = new AbortController();

    document.addEventListener('click', (e) => {
      const popupActive = popup.classList.contains('active');

      // Don't close popup if clicking inside the popup
      if (popup.contains(e.target)) {
        return;
      }

      // Close popup on any other click
      if (popupActive) {
        // Stop event propagation to prevent lightbox from opening
        e.stopPropagation();

        popup.classList.remove('active');
        container.removeAttribute('data-popup-open');

        // Animate zoom out smoothly
        const img = container.querySelector('img');
        const hotspotsOverlay = container.querySelector('[class*="absolute"][style*="left"]');
        if (img) {
          img.classList.remove('hotspot-zoom');
          // Trigger reflow to ensure animation plays
          void img.offsetHeight;
        }
        if (hotspotsOverlay) {
          hotspotsOverlay.style.transform = 'scale(1)';
          // Clear transformOrigin after animation completes
          setTimeout(() => {
            hotspotsOverlay.style.transformOrigin = '';
          }, 300);
        }
      }
    }, { signal: controller.signal });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        popup.classList.remove('active');
        container.removeAttribute('data-popup-open');

        // Animate zoom out smoothly (Issue 2)
        const img = container.querySelector('img');
        const hotspotsOverlay = container.querySelector('[class*="absolute"][style*="left"]');
        if (img) {
          img.classList.remove('hotspot-zoom');
          // Trigger reflow to ensure animation plays
          void img.offsetHeight;
        }
        if (hotspotsOverlay) {
          hotspotsOverlay.style.transform = 'scale(1)';
          // Clear transformOrigin after animation completes
          setTimeout(() => {
            hotspotsOverlay.style.transformOrigin = '';
          }, 300);
        }
      }
    }, { signal: controller.signal });
  });
</script>

<style>
  /* Button base styling */
  button[data-hotspot-id] {
    transition: filter 0.15s ease;
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    outline: none !important;
  }

  /* Remove unwanted pseudo-elements */
  button[data-hotspot-id]::after,
  button[data-hotspot-id]::before {
    display: none !important;
  }

  /* Button hover glow effect */
  button[data-hotspot-id]:hover {
    filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.3));
  }

  button[data-hotspot-id]:focus {
    outline: none;
  }

  /* Outer white border layer: fills entire button */
  button[data-hotspot-id] > span:nth-child(1) {
    inset: 0;
  }

  /* Middle black circle: 4% inset (~0.96px of 24px button, ~92% of parent size) */
  button[data-hotspot-id] > span:nth-child(2) {
    inset: 4%;
  }

  button[data-hotspot-id]:hover > span:nth-child(2) {
    opacity: 0.9;
  }

  /* Inner white dot: 28% inset at rest, shrinks to 10% on hover */
  button[data-hotspot-id] > span:nth-child(3) {
    inset: 28%;
  }

  button[data-hotspot-id]:hover > span:nth-child(3) {
    inset: 38%;
  }

  /* Image zoom effect */
  [data-hotspot-image] > img.hotspot-zoom {
    transform: scale(1.1);
    transition: transform 0.3s ease;
  }
</style>
