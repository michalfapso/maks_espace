---
interface Props {
  gap?: string;
}

const { gap = '2rem' } = Astro.props;
---

<div class="balanced-columns columns-1 md:columns-2" style={`column-gap: ${gap};`}>
  <slot />
</div>

<style>
  .balanced-columns {
    column-fill: balance;
  }

  :global(div > div) {
    break-inside: avoid;
  }
</style>
