---
// src/pages/cs/pro-investory.astro
import PageLayout from '@layouts/PageLayout.astro';
import ContactForm from '@components/ui/ContactForm.astro';

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID;
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER;
---

<PageLayout
  title="Investiční příležitost – É-space | HPM"
  description="É-space: CO₂-neutrální prefabrikované zahradní kanceláře z konopí a slámy. Investiční příležitost na trhu CZ/SK."
  lang="cs"
  pathname="/cs/pro-investory/"
>
  {/* Hero */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h1 class="text-4xl font-bold text-wood mb-4">Investiční příležitost: É-space</h1>
      <p class="text-xl font-medium text-wood tracking-wide">Prefabrikované zahradní kanceláře z konopí a slámy pro CZ/SK</p>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Problem */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Problém</h2>
      <ul class="space-y-3">
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Trh EU se „zahradními kancelářemi" (€2,5 mld., +15 % ročně) ovládají konvenční materiály (ocel, dřevo, plasty).</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Vysoké náklady na energii, špatná izolace a absence CO₂ certifikace.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Cílový trh (CZ/SK): <span class="text-amber font-bold text-xl">€50M/rok</span> — zákazníci požadují zelená řešení, ale nemají k nim přístup.</span>
        </li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Solution */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Řešení</h2>
      <p class="text-gray-600 mb-4">É-space dodává CO₂-neutrální prefabrikované zahradní kanceláře z konopocementu a slámy:</p>
      <ul class="space-y-3">
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Přírodní izolace (hodnota R 5–7× lepší než dřevo).</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>O 80 % nižší uhlíková stopa oproti tradičním materiálům.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Modulární, plug-and-play instalace (montáž za 7 dní).</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Certifikováno podle evropských nízkoenergetických standardů (nZEB).</span>
        </li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Market & Traction */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Trh &amp; trakce</h2>
      <div class="rounded-lg border border-wood/20 bg-amber/[0.06] overflow-hidden mb-6">
        <div class="grid grid-cols-2 md:grid-cols-4">
          <div class="px-6 py-5 text-center border-r border-b border-wood/20 md:border-b-0">
            <div class="text-amber font-bold text-3xl">€2.5B</div>
            <div class="text-sm text-gray-500 mt-1">Trh zahradních kanceláří v EU</div>
          </div>
          <div class="px-6 py-5 text-center border-b border-wood/20 md:border-b-0 md:border-r">
            <div class="text-amber font-bold text-3xl">+15%</div>
            <div class="text-sm text-gray-500 mt-1">roční růst (r/r)</div>
          </div>
          <div class="px-6 py-5 text-center border-r border-wood/20 md:border-l md:border-r-0">
            <div class="text-amber font-bold text-3xl">200+</div>
            <div class="text-sm text-gray-500 mt-1">kvalifikovaných leadů za 3 měsíce</div>
          </div>
          <div class="px-6 py-5 text-center md:border-l border-wood/20">
            <div class="text-amber font-bold text-3xl">3</div>
            <div class="text-sm text-gray-500 mt-1">LOI od developerů v Praze &amp; Bratislavě</div>
          </div>
        </div>
      </div>
      <ul class="space-y-3">
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Cílový trh CZ/SK: €50M/rok, nedostatečně pokrytý ekořešeními.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>200+ kvalifikovaných leadů za 3 měsíce bez marketingových výdajů.</span>
        </li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Business Model */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Obchodní model</h2>
      <ul class="space-y-3">
        <li><strong>B2B:</strong> Prodej stavebním firmám, architektům, provozovatelům coworkingů.</li>
        <li><strong>B2C:</strong> Přímý prodej přes web + maloobchodní partneři.</li>
        <li><strong>Marže:</strong> <span class="text-amber font-bold text-xl">40–50 % hrubé</span> marže v sériové výrobě (€15 tis./jednotka při průměrném prodeji €40 tis.).</li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Roadmap */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Harmonogram</h2>
      <ul class="space-y-4">
        <li><strong>Q1 2026:</strong> Certifikace + nastavení výrobní linky.</li>
        <li><strong>Q2 2026:</strong> První prodeje + dodávky.</li>
        <li><strong>Q3–Q4 2026:</strong> Expanze na trhy D+A/CH.</li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Why Us */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Proč my</h2>
      <ul class="space-y-3">
        <li><strong>IP:</strong> Patentovaný modulární systém + kompozit konopí a slámy.</li>
        <li><strong>Tým:</strong> Tým s 15+ lety zkušeností v prefabrikaci a udržitelnosti.</li>
        <li><strong>Ekologické pověření:</strong> CO₂-certifikováno, materiály cradle-to-cradle.</li>
        <li><strong>Riziko:</strong> Technologie je ověřená; trh roste.</li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Investment Ask */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Investiční požadavek</h2>
      <div class="border border-wood/20 rounded-lg bg-amber/[0.04] p-6">
        <div class="flex gap-12 mb-6 pb-6 border-b border-wood/15">
          <div class="text-center">
            <div class="text-amber font-bold text-3xl">€500K</div>
            <div class="text-sm text-gray-500 mt-1">Investice</div>
          </div>
          <div class="text-center">
            <div class="text-amber font-bold text-3xl">20%</div>
            <div class="text-sm text-gray-500 mt-1">Podíl</div>
          </div>
          <div class="text-center">
            <div class="text-amber font-bold text-3xl">€2.5M</div>
            <div class="text-sm text-gray-500 mt-1">Předpeněžní ocenění</div>
          </div>
        </div>
        <p class="font-medium mb-3">Použití prostředků:</p>
        <ul class="space-y-2">
          <li class="flex gap-3">
            <span class="text-amber font-bold">•</span>
            <span>€200 tis.: Certifikace + výrobní linka.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-amber font-bold">•</span>
            <span>€150 tis.: Marketing + prodej.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-amber font-bold">•</span>
            <span>€150 tis.: Provozní kapitál.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Exit */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Výstup</h2>
      <ul class="space-y-3">
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Akvizice evropským lídrem v prefabrikaci (např. Häussermann, Wainer).</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Škálování na <span class="text-amber font-bold text-xl">€10M ARR do roku 2028</span> (3× růst odvětví).</span>
        </li>
      </ul>
    </div>
  </section>

  {/* Contact Form */}
  <ContactForm lang="cs" formspreeId={formspreeId} whatsappNumber={whatsappNumber} />
</PageLayout>
