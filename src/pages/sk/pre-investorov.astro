---
// src/pages/sk/pre-investorov.astro
import PageLayout from '@layouts/PageLayout.astro';
import ContactForm from '@components/ui/ContactForm.astro';

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID;
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER;
---

<PageLayout
  title="Investičná príležitosť – É-space | HPM"
  description="É-space: CO₂-neutrálne prefabrikované záhradné kancelárie z konope a slamy. Investičná príležitosť na trhu CZ/SK."
  lang="sk"
  pathname="/sk/pre-investorov/"
>
  {/* Hero */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h1 class="text-4xl font-bold text-wood mb-4">Investičná príležitosť: É-space</h1>
      <p class="text-xl font-medium text-wood tracking-wide">Prefabrikované záhradné kancelárie z konope a slamy pre CZ/SK</p>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Problem */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Problém</h2>
      <ul class="space-y-3">
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Trh EÚ so „záhradnými kanceláriami" (€2,5 mld., +15 % ročne) ovládajú konvenčné materiály (oceľ, drevo, plasty).</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Vysoké náklady na energiu, zlá izolácia a absencia CO₂ certifikácie.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Cieľový trh (CZ/SK): <span class="text-amber font-bold text-xl">€50M/rok</span> — zákazníci požadujú zelené riešenia, no nemajú k nim prístup.</span>
        </li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Solution */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Riešenie</h2>
      <p class="text-gray-600 mb-4">É-space dodáva CO₂-neutrálne prefabrikované záhradné kancelárie z konopocementu a slamy:</p>
      <ul class="space-y-3">
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Prírodná izolácia (hodnota R 5–7× lepšia ako drevo).</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>O 80 % nižší uhlíkový odtlačok oproti tradičným materiálom.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Modulárna, plug-and-play inštalácia (montáž za 7 dní).</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Certifikované podľa európskych nízkoenergetických štandardov (nZEB).</span>
        </li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Market & Traction */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Trh &amp; trakcia</h2>
      <div class="rounded-lg border border-wood/20 bg-amber/[0.06] overflow-hidden mb-6">
        <div class="grid grid-cols-2 md:grid-cols-4">
          <div class="px-6 py-5 text-center border-r border-b border-wood/20 md:border-b-0">
            <div class="text-amber font-bold text-3xl">€2.5B</div>
            <div class="text-sm text-gray-500 mt-1">Trh záhradných kancelárií v EÚ</div>
          </div>
          <div class="px-6 py-5 text-center border-b border-wood/20 md:border-b-0 md:border-r">
            <div class="text-amber font-bold text-3xl">+15%</div>
            <div class="text-sm text-gray-500 mt-1">ročný rast (r/r)</div>
          </div>
          <div class="px-6 py-5 text-center border-r border-wood/20 md:border-l md:border-r-0">
            <div class="text-amber font-bold text-3xl">200+</div>
            <div class="text-sm text-gray-500 mt-1">kvalifikovaných leadov za 3 mesiace</div>
          </div>
          <div class="px-6 py-5 text-center md:border-l border-wood/20">
            <div class="text-amber font-bold text-3xl">3</div>
            <div class="text-sm text-gray-500 mt-1">LOI od developerov v Prahe &amp; Bratislave</div>
          </div>
        </div>
      </div>
      <ul class="space-y-3">
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Cieľový trh CZ/SK: €50M/rok, nedostatočne pokrytý ekoriešeniami.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>200+ kvalifikovaných leadov za 3 mesiace bez marketingových výdavkov.</span>
        </li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Business Model */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Obchodný model</h2>
      <ul class="space-y-3">
        <li><strong>B2B:</strong> Predaj stavebným firmám, architektom, prevádzkovateľom coworkingov.</li>
        <li><strong>B2C:</strong> Priamy predaj cez web + maloobchodní partneri.</li>
        <li><strong>Marža:</strong> <span class="text-amber font-bold text-xl">40–50 % hrubej</span> marže v sériovej výrobe (€15 tis./jednotka pri priemernom predaji €40 tis.).</li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Roadmap */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Plán rozvoja</h2>
      <ul class="space-y-4">
        <li><strong>Q1 2026:</strong> Certifikácie + nastavenie výrobnej linky.</li>
        <li><strong>Q2 2026:</strong> Prvé predaje + dodávky.</li>
        <li><strong>Q3–Q4 2026:</strong> Expanzia na trhy D+A/CH.</li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Why Us */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Prečo my</h2>
      <ul class="space-y-3">
        <li><strong>IP:</strong> Patentovaný modulárny systém + kompozit konope a slamy.</li>
        <li><strong>Tím:</strong> Tím s 15+ rokmi skúseností v prefabrikácii a udržateľnosti.</li>
        <li><strong>Ekologické poverenia:</strong> CO₂-certifikované, materiály cradle-to-cradle.</li>
        <li><strong>Riziko:</strong> Technológia je overená; trh rastie.</li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Investment Ask */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Investičná požiadavka</h2>
      <div class="border border-wood/20 rounded-lg bg-amber/[0.04] p-6">
        <div class="flex gap-12 mb-6 pb-6 border-b border-wood/15">
          <div class="text-center">
            <div class="text-amber font-bold text-3xl">€500K</div>
            <div class="text-sm text-gray-500 mt-1">Investícia</div>
          </div>
          <div class="text-center">
            <div class="text-amber font-bold text-3xl">20%</div>
            <div class="text-sm text-gray-500 mt-1">Podiel</div>
          </div>
          <div class="text-center">
            <div class="text-amber font-bold text-3xl">€2.5M</div>
            <div class="text-sm text-gray-500 mt-1">Predpeniažné ocenenie</div>
          </div>
        </div>
        <p class="font-medium mb-3">Použitie prostriedkov:</p>
        <ul class="space-y-2">
          <li class="flex gap-3">
            <span class="text-amber font-bold">•</span>
            <span>€200 tis.: Certifikácie + výrobná linka.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-amber font-bold">•</span>
            <span>€150 tis.: Marketing + predaj.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-amber font-bold">•</span>
            <span>€150 tis.: Prevádzkový kapitál.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Exit */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Výstup</h2>
      <ul class="space-y-3">
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Akvizícia európskym lídrom v prefabrikácii (napr. Häussermann, Wainer).</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Škálovanie na <span class="text-amber font-bold text-xl">€10M ARR do roku 2028</span> (3× rast odvetvia).</span>
        </li>
      </ul>
    </div>
  </section>

  {/* Contact Form */}
  <ContactForm lang="sk" formspreeId={formspreeId} whatsappNumber={whatsappNumber} />
</PageLayout>
