---
// src/pages/en/for-investors.astro
import PageLayout from '@layouts/PageLayout.astro';
import ContactForm from '@components/ui/ContactForm.astro';

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID;
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER;
---

<PageLayout
  title="Investment Opportunity – É-space | HPM"
  description="É-space: CO₂-neutral prefabricated hemp &amp; straw garden offices. Investment opportunity in the CZ/SK market."
  lang="en"
  pathname="/en/for-investors/"
>
  {/* Hero */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h1 class="text-4xl font-bold text-wood mb-4">Investment Opportunity: É-space</h1>
      <p class="text-lg text-gray-600">Prefabricated Hemp &amp; Straw Garden Offices for CZ/SK</p>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Problem */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Problem</h2>
      <ul class="space-y-3">
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>The EU "garden offices" market (€2.5B, +15% YoY) is dominated by conventional materials (steel, wood, plastics).</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>High energy costs, poor insulation, and lack of CO₂ certification.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Target market (CZ/SK): <span class="text-amber font-bold text-xl">€50M/year</span> — customers demand green solutions but have limited access.</span>
        </li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Solution */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Solution</h2>
      <p class="text-gray-600 mb-4">É-space delivers CO₂-neutral, prefabricated garden offices using hempcrete &amp; straw:</p>
      <ul class="space-y-3">
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Natural insulation (R-value 5–7× better than wood).</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>80% less embodied carbon vs. traditional materials.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Modular, plug-and-play installation (7-day setup).</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Certified for EU low-energy standards (nZEB).</span>
        </li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Market & Traction */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Market &amp; Traction</h2>
      <div class="rounded-lg border border-wood/20 bg-amber/[0.06] overflow-hidden mb-6">
        <div class="grid grid-cols-2 md:grid-cols-4">
          <div class="px-6 py-5 text-center border-r border-b border-wood/20 md:border-b-0">
            <div class="text-amber font-bold text-3xl">€2.5B</div>
            <div class="text-sm text-gray-500 mt-1">EU garden office market</div>
          </div>
          <div class="px-6 py-5 text-center border-b border-wood/20 md:border-b-0 md:border-r">
            <div class="text-amber font-bold text-3xl">+15%</div>
            <div class="text-sm text-gray-500 mt-1">annual growth (YoY)</div>
          </div>
          <div class="px-6 py-5 text-center border-r border-wood/20 md:border-l md:border-r-0">
            <div class="text-amber font-bold text-3xl">200+</div>
            <div class="text-sm text-gray-500 mt-1">qualified leads in 3 months</div>
          </div>
          <div class="px-6 py-5 text-center md:border-l border-wood/20">
            <div class="text-amber font-bold text-3xl">3</div>
            <div class="text-sm text-gray-500 mt-1">LOIs from Prague &amp; Bratislava developers</div>
          </div>
        </div>
      </div>
      <ul class="space-y-3">
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>CZ/SK target: €50M/year, underserved by eco-solutions.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>200+ qualified leads in 3 months with no marketing spend.</span>
        </li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Business Model */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Business Model</h2>
      <ul class="space-y-3">
        <li><strong>B2B:</strong> Sell to builders, architects, coworking operators.</li>
        <li><strong>B2C:</strong> Direct sales via web + retail partners.</li>
        <li><strong>Margin:</strong> <span class="text-amber font-bold text-xl">40–50% gross</span> at scale (€15k/unit on €40k avg. sale).</li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Roadmap */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Roadmap</h2>
      <ul class="space-y-4">
        <li><strong>Q1 2026:</strong> Certifications + production line setup.</li>
        <li><strong>Q2 2026:</strong> First sales + deliveries.</li>
        <li><strong>Q3–Q4 2026:</strong> Expand to D+A/CH markets.</li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Why Us */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Why Us</h2>
      <ul class="space-y-3">
        <li><strong>IP:</strong> Patented modular system + hemp-straw composite.</li>
        <li><strong>Team:</strong> 15+ years in prefab + sustainability.</li>
        <li><strong>Eco-credentials:</strong> CO₂-certified, cradle-to-cradle materials.</li>
        <li><strong>Risk:</strong> Technology is proven; market is growing.</li>
      </ul>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Investment Ask */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Investment Ask</h2>
      <div class="border border-wood/20 rounded-lg bg-amber/[0.04] p-6">
        <div class="flex gap-12 mb-6 pb-6 border-b border-wood/15">
          <div class="text-center">
            <div class="text-amber font-bold text-3xl">€500K</div>
            <div class="text-sm text-gray-500 mt-1">Investment</div>
          </div>
          <div class="text-center">
            <div class="text-amber font-bold text-3xl">20%</div>
            <div class="text-sm text-gray-500 mt-1">Equity</div>
          </div>
          <div class="text-center">
            <div class="text-amber font-bold text-3xl">€2.5M</div>
            <div class="text-sm text-gray-500 mt-1">Pre-money valuation</div>
          </div>
        </div>
        <p class="font-medium mb-3">Use of funds:</p>
        <ul class="space-y-2">
          <li class="flex gap-3">
            <span class="text-amber font-bold">•</span>
            <span>€200K: Certifications + production line.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-amber font-bold">•</span>
            <span>€150K: Marketing + sales.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-amber font-bold">•</span>
            <span>€150K: Working capital.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <div class="container max-w-3xl"><hr class="border-t border-wood/10" /></div>

  {/* Exit */}
  <section class="section-padding-sm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold text-wood mb-4">Exit</h2>
      <ul class="space-y-3">
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Acquisition by EU prefab leader (e.g., Häussermann, Wainer).</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber font-bold">•</span>
          <span>Scale-up to <span class="text-amber font-bold text-xl">€10M ARR by 2028</span> (3× industry growth).</span>
        </li>
      </ul>
    </div>
  </section>

  {/* Contact Form */}
  <ContactForm lang="en" formspreeId={formspreeId} whatsappNumber={whatsappNumber} />
</PageLayout>
